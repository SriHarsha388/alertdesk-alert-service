{
  "info": {
    "_postman_id": "6f5fd430-39f0-4edc-b0ef-3ff4b6cb4b1d",
    "name": "AlertDesk Alert Service",
    "description": "Postman collection generated from the current Spring API in alertdesk-alert-service.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "alertId",
      "value": "ALT-00001"
    },
    {
      "key": "newAlertId",
      "value": "ALT-99999"
    }
  ],
  "item": [
    {
      "name": "List Alerts",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/alerts?page=0&size=20&status=UNDER_REVIEW&riskBand=HIGH&alertType=APP_SCAM&amountMin=20000&amountMax=40000&sortBy=amount&sortDir=asc",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "alerts"
          ],
          "query": [
            {
              "key": "page",
              "value": "0"
            },
            {
              "key": "size",
              "value": "20"
            },
            {
              "key": "status",
              "value": "UNDER_REVIEW"
            },
            {
              "key": "riskBand",
              "value": "HIGH"
            },
            {
              "key": "alertType",
              "value": "APP_SCAM"
            },
            {
              "key": "amountMin",
              "value": "20000"
            },
            {
              "key": "amountMax",
              "value": "40000"
            },
            {
              "key": "sortBy",
              "value": "amount"
            },
            {
              "key": "sortDir",
              "value": "asc"
            }
          ]
        },
        "description": "Returns a paginated alert list. All filters are optional and use AND logic when combined. Valid sortBy values are triggeredAt, amount, status, riskBand. Valid sortDir values are desc and asc."
      },
      "response": []
    },
    {
      "name": "Get Alert By Id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/alerts/{{alertId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "alerts",
            "{{alertId}}"
          ]
        },
        "description": "Fetches a single alert by its ID."
      },
      "response": []
    },
    {
      "name": "Create Alert",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"alertId\": \"{{newAlertId}}\",\n  \"customerId\": \"CUST-0001\",\n  \"alertType\": \"APP_SCAM\",\n  \"riskBand\": \"HIGH\",\n  \"amount\": 100.50,\n  \"currency\": \"GBP\",\n  \"triggeredAt\": \"2024-03-10T10:00:00Z\",\n  \"status\": \"NEW\",\n  \"assignedAnalyst\": null,\n  \"flaggedRules\": [\"TEST_RULE\"]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/alerts",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "alerts"
          ]
        },
        "description": "Creates a new alert. Valid values include alertType: STRUCTURING, APP_SCAM, SANCTIONS_HIT, UNUSUAL_ACTIVITY, ACCOUNT_TAKEOVER; riskBand: HIGH, MEDIUM, LOW; status: NEW, UNDER_REVIEW, ESCALATED, CLOSED."
      },
      "response": []
    },
    {
      "name": "Update Alert Status",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"UNDER_REVIEW\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/alerts/{{alertId}}/status",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "alerts",
            "{{alertId}}",
            "status"
          ]
        },
        "description": "Updates the lifecycle status of an alert. Valid transitions are NEW -> UNDER_REVIEW -> ESCALATED -> CLOSED."
      },
      "response": []
    },
    {
      "name": "Get Alert Summary",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/alerts/summary?groupBy=status",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "alerts",
            "summary"
          ],
          "query": [
            {
              "key": "groupBy",
              "value": "status"
            }
          ]
        },
        "description": "Returns alert counts grouped by one of: status, riskBand, alertType."
      },
      "response": []
    }
  ]
}
